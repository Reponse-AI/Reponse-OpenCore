# ─── Reponse API ────────────────────────────────────────────────────────────────
# All vars are server-only. Client components receive them at runtime via
# window.__ENV, injected by app/layout.tsx — no NEXT_PUBLIC_ prefix needed.
REPONSE_API_URL=https://reponse.ai/api
REPONSE_WORKSPACE_ID=your-workspace-uuid
# Optional — only for authenticated (non-public) API operations
REPONSE_API_KEY=rp_live_your_key_here

# ─── Store ──────────────────────────────────────────────────────────────────────
STORE_NAME=Reponse Store
SITE_URL=http://localhost:3000
MARKET_ID=your-market-uuid

# ─── Checkout ───────────────────────────────────────────────────────────────────
# "embedded" = Stripe Elements on your storefront (default)
# "redirect" = Redirect to Stripe Checkout
CHECKOUT_MODE=embedded
STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
